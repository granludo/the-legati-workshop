# Environment and secrets — never in git
.env
*.env.local

# Claude Code — track only the project-wide settings file
.claude/*
!.claude/settings.json

# Obsidian workspace state
.obsidian/

# OS files
.DS_Store
Thumbs.db

# Large source media — keep on disk, not in git
*.mp4
*.webm
*.m4a
*.mov
*.mkv
*.wav
*.mp3
*.aac

# Large PDFs — document in sources/INDEX.md, don't track the binary
# Exception: small reference PDFs you want version-controlled can be force-added
sources/**/*.pdf

# Generated PDFs (can be regenerated with /md2pdf)
TO-READ/*
!TO-READ/.gitkeep
!TO-READ/*.md

# Processing queues — track .md notes, not the raw media
TO-PROCESS/*
!TO-PROCESS/.gitkeep
!TO-PROCESS/*.md

# Python tooling leftovers
__pycache__/
*.pyc
.venv/

# Derived / regenerable databases (source of truth is the .md files)
*.db
*.sqlite
*.sqlite3

# Browser automation run artefacts (the script is the asset, not the run)
tools/*/outputs/*
!tools/*/outputs/.gitkeep

# Transcription run logs
whisper.log
transcribe.log

# Confidential — per-user private documents (invoices, signed scans, etc.)
confidential/

# Wiki/embedding cache artefacts (rebuildable)
wiki/*/_embeddings.json

# Corpus / bulk data generated by automation scripts
**/.corpus/
